#!/bin/bash
# Daily update check agent for the Taufinity CLI.
# Called by launchd (io.taufinity.cli) at 09:00.
#
# Exit codes from `taufinity update --check`:
#   0 = up to date
#   1 = update available
#   * = error — reported to Studio via `taufinity agent report-error`

BINARY="/usr/local/bin/taufinity"

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

notify_update() {
  # terminal-notifier gives a clickable action that opens Terminal to run the update.
  # Falls back to a plain macOS notification when not installed (brew install terminal-notifier).
  if command -v terminal-notifier &>/dev/null; then
    terminal-notifier \
      -title "Taufinity CLI" \
      -subtitle "Update available" \
      -message "Run: taufinity update" \
      -execute "osascript -e 'tell application \"Terminal\" to activate' -e 'tell application \"Terminal\" to do script \"taufinity update\"'" \
      2>/dev/null || true
  else
    osascript -e 'display notification "Run: taufinity update" with title "Taufinity CLI" subtitle "Update available"' \
      2>/dev/null || true
  fi
}

# Guard: binary missing (e.g. manual removal without uninstalling the cask).
# Exit 0 so launchd does not throttle or restart the agent on every interval.
if [ ! -x "$BINARY" ]; then
  log "ERROR (exit 127): binary not found at $BINARY"
  exit 0
fi

# Run the update check; capture exit code without triggering set -e.
CHECK_EXIT=0
OUTPUT=$("$BINARY" update --check 2>&1) || CHECK_EXIT=$?

case "$CHECK_EXIT" in
  0)
    log "Up to date"
    ;;
  1)
    log "Update available — firing notification"
    notify_update
    ;;
  *)
    log "ERROR (exit $CHECK_EXIT): ${OUTPUT:-update check failed}"
    "$BINARY" agent report-error \
      --exit-code "$CHECK_EXIT" \
      --message "${OUTPUT:-update check failed}" \
      2>/dev/null || true
    ;;
esac
