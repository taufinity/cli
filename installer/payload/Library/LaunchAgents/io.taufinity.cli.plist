<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.taufinity.cli</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/taufinity-update-check</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/io.taufinity.cli.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/io.taufinity.cli.log</string>
</dict>
</plist>
